# ── MateFi Relayer environment ────────────────────────────────────────────
# Copy to .env and fill in values. Unset contract IDs => relayer runs in
# local/off-chain mode (all contract calls become warning-logged no-ops).

# Stellar
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
RELAYER_SECRET=                              # S... relayer keypair secret key

# Contract addresses (populated after deploy)
MATCH_REGISTRY_CONTRACT_ID=
ESCROW_VAULT_CONTRACT_ID=
PREDICTION_POOL_CONTRACT_ID=
ORACLE_GATEWAY_CONTRACT_ID=
SETTLEMENT_CONTRACT_ID=
USDC_CONTRACT_ID=                            # Testnet USDC SAC address
TREASURY_ADDRESS=                            # G... treasury Stellar address

# Database
# MongoDB connection. Local: mongodb://localhost:27017
# MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=matefi

# Server
PORT=3000
WS_PORT=3001

# Relayer behaviour
DEV_MODE=true                                # true => off-chain match lifecycle via REST
STOCKFISH_DEPTH=18                           # default analysis depth
EVAL_THRESHOLD=250                           # centipawns, market lock threshold
EVENT_POLL_INTERVAL_MS=5000                  # Soroban getEvents polling interval

# Anti-cheat (move-match scoring against Stockfish)
ANTICHEAT_DEPTH=14                           # shallower than STOCKFISH_DEPTH — runs on every move
ANTICHEAT_SUSPICION_THRESHOLD=0.85           # top-1 engine-match rate that triggers a flag
ANTICHEAT_MIN_MOVES=15                       # minimum analyzed moves before a flag can fire
ANTICHEAT_OPENING_CUTOFF_PLY=8               # skip the opening when scoring

# Dispute window keeper (contracts/settlement)
DISPUTE_KEEPER_INTERVAL_MS=60000             # how often to poll for matches due for finalize()
CHALLENGE_WINDOW_SECS=3600                   # must match Settlement's on-chain challenge window
