# MateFi frontend environment — copy to .env.local and fill in.
# All values are public (bundled into the client).

# Stellar network
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Relayer endpoints
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Soroban contract IDs — populated after `scripts/deploy-all.sh`.
# Leave empty before deployment: the UI degrades gracefully and disables
# on-chain actions with a "contracts not deployed yet" notice.
NEXT_PUBLIC_MATCH_REGISTRY_ID=
NEXT_PUBLIC_ESCROW_VAULT_ID=
NEXT_PUBLIC_PREDICTION_POOL_ID=
NEXT_PUBLIC_ORACLE_GATEWAY_ID=
NEXT_PUBLIC_SETTLEMENT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=
